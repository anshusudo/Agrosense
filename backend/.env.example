# =============================
# AgroSense Backend Environment
# =============================

# Server
PORT=5000

# Database (required)
MONGODB_URI=mongodb://127.0.0.1:27017/agrosense

# Auth (required)
JWT_SECRET=replace_with_a_strong_secret_key

# Weather API (required)
WEATHER_API_KEY=your_openweather_api_key

# Chatbot - Groq (free cloud API)
GROQ_API_KEY=your_groq_api_key_here

# Email (required for OTP + report email)
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_email_app_password
EMAIL_FROM=your_email@gmail.com

# Optional (only if you use SendGrid logic elsewhere)
SENDGRID_API_KEY=

# Optional startup behavior
# Keep false in normal development/production
RUN_STARTUP_EMAIL_TEST=false
